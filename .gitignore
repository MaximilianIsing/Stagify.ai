# Dependencies
node_modules/
npm-debug.log*

# Environment variables (real secrets for local dev live in .env — never commit it)
.env
.env.local
.env.production
!.env.example

# API keys & secrets now live in a single local .env (see .env.example for the
# template). Legacy per-secret *.txt files are covered by the *.txt rule below.

# Temporary files
*.tmp
*.temp
/tmp/

# Logs
*.log
logs/
/data/

# Runtime data
pids/
*.pid
*.seed

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Build output
dist/
build/

# Playwright e2e artifacts (browsers live in the OS cache, not the repo)
test-results/
playwright-report/
blob-report/
.playwright/
# Litestream binary — downloaded into ./bin during the Render build, never committed
bin/

# Text files (but allow specific ones)
*.txt
!public/robots.txt

.claude/
# design-sync generated bundle (regenerable from design-system/ + public/fonts)
ds-bundle/
CLAUDE.md