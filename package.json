{
  "name": "stagify-ai",
  "version": "2.1.0",
  "type": "module",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node --import ./instrument.js server.js",
    "dev": "nodemon --import ./instrument.js server.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && node --test \"test/**/*.test.js\"",
    "test:coverage": "node scripts/test-coverage.js",
    "test:e2e": "playwright test",
    "lint": "eslint . --max-warnings=0"
  },
  "author": "Maximilian Ising",
  "license": "ISC",
  "description": "AI virtual-staging web app (Node/Express).",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^10.63.0",
    "better-sqlite3": "^12.11.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "form-data": "^4.0.4",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.2.0",
    "multer": "^2.0.2",
    "openai": "^4.28.0",
    "resend": "^6.6.0",
    "sharp": "^0.33.5",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "nodemon": "^3.0.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
