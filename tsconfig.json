{
  // Type-CHECK only — never a build step. `node server.js` still runs the .js
  // files directly and untouched; tsc runs as a linter (`npm run typecheck`,
  // wired into `npm test` so a type error blocks the Render deploy like a red
  // test does). We emit nothing (noEmit) and compile nothing.
  //
  // The @ts-nocheck ratchet is fully paid off: every backend file below is
  // genuinely checked — there are no opt-out pragmas left, and a new file is
  // checked from day one. Keep it that way (don't reintroduce @ts-nocheck);
  // tighten the loose flags below (strict, noImplicitAny) before adding surface,
  // not after.
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],

    // strictNullChecks is ON: null/undefined must be handled, not silently
    // dereferenced — this is the flag that actually catches "possibly undefined"
    // bugs, so it leads the strict rollout. The rest of `strict` and
    // `noImplicitAny` stay off for now (noImplicitAny is a large, mostly
    // mechanical @param sweep); tighten those next, not before.
    // NOTE: useUnknownInCatchVariables defaults to false while strict is off, so
    // catch bindings stay `any` — don't set `strict: true` without also handling
    // the ~60 catch-clause narrowings that flips on.
    "strict": false,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["server.js", "instrument.js", "load-env.js", "lib/**/*.js", "routes/**/*.js", "lib/types/**/*.d.ts"],
  "exclude": ["node_modules"]
}
